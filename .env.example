VITE_PATREON_CLIENT_ID=your-patreon-client-id
VITE_KOFI_CLIENT_ID=your-kofi-client-id
VITE_TWITCH_CLIENT_ID=your-twitch-client-id
VITE_TWITTER_CLIENT_ID=your-twitter-client-id
VITE_INSTAGRAM_CLIENT_ID=your-instagram-client-id

# App Configuration
VITE_APP_URL=http://localhost:5173
